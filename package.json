{
  "name": "subdivision-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:resident": "npm run start --workspace=apps/resident-app",
    "dev:guard": "npm run start --workspace=apps/guard-app",
    "apk:resident": "npm run apk --workspace=apps/resident-app",
    "apk:guard": "npm run apk --workspace=apps/guard-app",
    "apk:all": "npm run apk:resident && npm run apk:guard",
    "embed:resident": "npm run android:embed --workspace=apps/resident-app",
    "embed:guard": "npm run android:embed --workspace=apps/guard-app",
    "embed:all": "npm run embed:resident && npm run embed:guard",
    "apk:resident:local": "npm run android:apk --workspace=apps/resident-app",
    "apk:guard:local": "npm run android:apk --workspace=apps/guard-app",
    "apk:all:local": "npm run apk:resident:local && npm run apk:guard:local",
    "install:all": "npm install",
    "lint:resident": "npm run lint --workspace=apps/resident-app",
    "lint:guard": "npm run lint --workspace=apps/guard-app",
    "lint:frontend": "npm run lint:resident && npm run lint:guard",
    "lint:backend": "composer --working-dir backend run lint",
    "lint": "npm run lint:frontend && npm run lint:backend"
  }
}
